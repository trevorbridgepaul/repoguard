# Copy to .env and adjust as needed. Not required when running via
# docker-compose (the app service sets DATABASE_URL itself); use this
# when running the app or alembic outside docker-compose, e.g. against
# a locally published Postgres port.

DATABASE_URL=postgresql+psycopg://repoguard:repoguard@localhost:5432/repoguard

# JWT signing secret. The default below is insecure and committed to
# the repo on purpose, for zero-setup local dev/CI — override it with
# a real random value for any deployment that isn't just your machine.
SECRET_KEY=dev-only-insecure-secret-change-me
